  status           String   @default("pending") // pending | approved | rejected
  message          String?
  resolvedByUserId Int?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([saleId, status])
  @@index([requesterUserId, status])
  @@index([createdAt])
}

model DamageRecord {
  id        Int                @id @default(autoincrement())
  reason    String
  note      String
  totalLoss Float
  fromType  String
  fromId    Int
  storeId   Int?
  store     Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  shopId    Int?
  shop      Shop?              @relation(fields: [shopId], references: [id], onDelete: SetNull)
  factoryId Int?
  factory   Factory?           @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     DamageRecordItem[]

  @@index([createdAt])
  @@index([storeId])
  @@index([shopId])
  @@index([factoryId])
}

model DamageRecordItem {
  id             Int          @id @default(autoincrement())
  damageRecordId Int
  itemType       String       @default("material")
  productId      Int?
  materialId     Int?
  quantity       Float
  lossPerUnit    Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  damageRecord   DamageRecord @relation(fields: [damageRecordId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id])
  material       Material?    @relation(fields: [materialId], references: [id])

  @@index([createdAt])
  @@index([itemType, productId, materialId])
}

model RepairOrder {
  id              Int      @id @default(autoincrement())
  reference       String   @unique
  destination     String
  shippingCost    Float    @default(0)
  document        String?
  note            String?
  status          String   @default("pending") // pending, in_progress, completed, failed
  from            String   // store, shop, factory
  fromId          Int
  accountId       Int?
  account         Accounts? @relation(fields: [accountId], references: [id])
  createdById     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           RepairOrderItem[]

  @@index([createdAt])
  @@index([status])
  @@index([from, fromId])
}

model RepairOrderItem {
  id          Int      @id @default(autoincrement())
  repairId    Int
  repair      RepairOrder @relation(fields: [repairId], references: [id], onDelete: Cascade)
  itemType    String   // product | material
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  materialId  Int?
  material    Material? @relation(fields: [materialId], references: [id])
  quantity    Float
  success     Float    @default(0)
  fail        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([repairId])
  @@index([itemType])
  @@index([productId])
  @@index([materialId])
}

model ValuedCustomer {
  id        Int      @id @default(autoincrement())
  image     String?  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt Boolean  @default(false) @map("deleted_at")

  @@map("valued_customers")
}

enum CollectionType {
  TOP_RATED
  FEATURED
  PREMIUM
}

model ProductCollection {
  id         Int            @id @default(autoincrement())
  productId  Int
  type       CollectionType
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  deletedAt  Boolean        @default(false) @map("deleted_at")

  product    Product        @relation(fields: [productId], references: [id])

  @@unique([productId, type, deletedAt])
  @@map("product_collections")
}

model HomeBanner {
  id          Int      @id @default(autoincrement())
  image       String?  
  heading     String   
  title       String   
  description String?  
  button      String? 
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   Boolean  @default(false) @map("deleted_at")

  @@map("home_banners")
}

model FoodCategory {
  id        Int      @id @default(autoincrement())
  name      String
  image     String?  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt Boolean  @default(false) @map("deleted_at")

  @@map("food_category")
}