  saleReturns SaleReturn[]
  isReturned  Boolean      @default(false)
  returnedAt  DateTime?
  transactions Transactions[]
  editAccessRequests SaleEditAccessRequest[]
  
  @@index([shopId])
  @@index([createdAt])
  @@index([shopId, createdAt])
  @@index([customerId, createdAt])
}

model SaleItem {
