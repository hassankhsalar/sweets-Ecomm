model Transfer {
  id            Int            @id @default(autoincrement())
  reference     String         @unique
  from          String
  fromId        Int
  fromStoreId   Int?
  fromStore     Store?         @relation("TransferFromStore", fields: [fromStoreId], references: [id], onDelete: SetNull)
  fromShopId    Int?
  fromShop      Shop?          @relation("TransferFromShop", fields: [fromShopId], references: [id], onDelete: SetNull)
  fromFactoryId Int?
  fromFactory   Factory?       @relation("TransferFromFactory", fields: [fromFactoryId], references: [id], onDelete: SetNull)
  to            String
  toId          Int
  toStoreId     Int?
  toStore       Store?         @relation("TransferToStore", fields: [toStoreId], references: [id], onDelete: SetNull)
  toShopId      Int?
  toShop        Shop?          @relation("TransferToShop", fields: [toShopId], references: [id], onDelete: SetNull)
  toFactoryId   Int?
  toFactory     Factory?       @relation("TransferToFactory", fields: [toFactoryId], references: [id], onDelete: SetNull)
  shipping_cost Float
  status        String         @default("processing")
  isRecived     Boolean?       @default(false)
  note          String?
  document      String?
  createdAt     DateTime  @default(now())
  requisitionId Int?
  requisitionSectionId Int?
  requisition   Requisition?      @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  requisitionSection RequisitionSection? @relation(fields: [requisitionSectionId], references: [id], onDelete: SetNull)
  transferItems TransferItem[]
  receipts      TransferReceipt[]

  @@index([requisitionId])
  @@index([requisitionSectionId])
  @@index([fromStoreId])
  @@index([fromShopId])
  @@index([fromFactoryId])
  @@index([toStoreId])
  @@index([toShopId])
  @@index([toFactoryId])
}

model Requisition {
  id                   Int                  @id @default(autoincrement())
  reference            String               @unique
  title                String?
  note                 String?
  requestType          String               @default("items")
  requestedAmount      Float?
  amountPurpose        String?
  currency             String?              @default("BDT")
  status               String               @default("pending")
  requesterType        String
  requesterId          Int
  requesterUserId      Int?
  requesterUser        User?                @relation("CreatedRequisitions", fields: [requesterUserId], references: [id], onDelete: SetNull)
  parentRequisitionId  Int?
  parentRequisition    Requisition?         @relation("RequisitionParent", fields: [parentRequisitionId], references: [id], onDelete: SetNull)
  childRequisitions    Requisition[]        @relation("RequisitionParent")
  approvedById         Int?
  approvedBy           User?                @relation("ApprovedRequisitions", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt           DateTime?
  isSegmented          Boolean              @default(false)
  segmentedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  items                RequisitionItem[]
  sections             RequisitionSection[]
  transfers            Transfer[]
  productions          Production[]

  @@index([requesterType, requesterId])
  @@index([status])
  @@index([parentRequisitionId])
  @@index([createdAt])
}

model RequisitionItem {
  id              Int          @id @default(autoincrement())
