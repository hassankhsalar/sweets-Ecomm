// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  username    String   @unique
  name        String?
  password    String
  isActive    Boolean  @default(true)
  deleted_at  Boolean  @default(false)
  bypassGlobalAccessWindow Boolean @default(false)
  sessionVersion Int   @default(0)
  loginStartTime String? @db.VarChar(5)
  loginEndTime   String? @db.VarChar(5)
  permissionId  Int?
  permission    Permission?  @relation(fields: [permissionId], references: [id])
  profile     Profile? @relation(fields: [profileId], references: [id])
  profileId   Int?     @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions   Transactions[]
  cashRegisterWithdraw  CashRegisterWithdraw[]
  cashRegisterDeposit   CashRegisterDeposit[]
  cashRegisterOpenedRecords  CashRegisterRecord[] @relation("CashRegisterOpenedBy")
  cashRegisterClosedRecords  CashRegisterRecord[] @relation("CashRegisterClosedBy")
  entityAccount             EntityAccount[]
  cashRegisterAssignment    CashRegisterAssignment[]
  userAssociate              UserAssociate[]
  employeeProfile            EmployeeProfile?
  leaveRequests              LeaveRequest[]
  leaveApprovals             LeaveApproval[]
  salaries                   Salary[]
  expenses                   Expense[]
  managerOf                  UserManager[] @relation("Manager")
  reportsTo                  UserManager[] @relation("Employee")
  
  clockIns     ClockInOut[]  @relation("ClockInOutUser")
  approvals    ClockInOut[]  @relation("ClockInOutApprovedBy")
  activityLogs ActivityLog[]
  createdRequisitions Requisition[] @relation("CreatedRequisitions")
  approvedRequisitions Requisition[] @relation("ApprovedRequisitions")
  assignedRequisitionSections RequisitionSection[] @relation("AssignedRequisitionSections")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  module      String
  action      String
  description String?  @db.Text
  entityId    Int?
  status      String   @default("success")
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([status])
  @@index([createdAt])
}

model Profile {
  id   Int     @id @default(autoincrement())
  bio  String?
  image String?
  user User?
}



model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique 
  permissions Json  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  
  users       User[]
  
  @@index([name])
}


model UserAssociate {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  associateName  String   // "store", "shop", "factory", "cashRegister", "account"
  associateId    Int      // ID of the specific entity
  

  @@unique([userId, associateName, associateId])
  @@index([userId])
  @@index([associateName, associateId])
}

model Accounts {
  id          Int       @id @default(autoincrement())
  name        String
  account_number   String    @unique
  balance     Float     @default(0)
  status      String
  deleted_at  Boolean  @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  transactions Transactions[]
  entityAssignments EntityAccount[]
  purchase     Purchase[]
  expenses     Expense[]
  repairOrders RepairOrder[]
  cashRegisterWithdraws CashRegisterWithdraw[]
  cashRegisterDeposits  CashRegisterDeposit[]

  @@index([createdAt])
}

model BankAccount {
  id                   Int       @id @default(autoincrement())
  name                String
  account_number      String    @unique
  starting_balance    Float     @default(0)
  current_balance     Float     @default(0)
  withdraw_charge     Float?
  deleted_at          Boolean   @default(false)
  transactions        Transactions[]
  sales               Sale[]
  cashRegisterWithdraws CashRegisterWithdraw[]
  cashRegisterDeposits  CashRegisterDeposit[]
}

model EmployeeProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation  String?
  baseSalary   Float    @default(0)
  salaryType   String   @default("monthly") // monthly, hourly
  joiningDate  DateTime?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserManager {
  id         Int      @id @default(autoincrement())
  userId     Int
  managerId  Int
  user       User     @relation("Employee", fields: [userId], references: [id], onDelete: Cascade)
  manager    User     @relation("Manager", fields: [managerId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, managerId])
  @@index([userId])
  @@index([managerId])
}

model ClockInOut {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("ClockInOutUser", fields: [userId], references: [id], onDelete: Cascade)
  clockIn      DateTime
  clockOut     DateTime?
  status       String   @default("open") // open, closed
  approvedById Int?
  approvedBy   User?    @relation("ClockInOutApprovedBy", fields: [approvedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([clockIn])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  isPaid      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model LeaveCategory {
  id          Int      @id @default(autoincrement())
  name        String
  isPaid      Boolean  @default(true)
  maxDays     Int?
  deleted_at  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  Int
  category    LeaveCategory @relation(fields: [categoryId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  approvals   LeaveApproval[]

  @@index([userId])
  @@index([categoryId])
  @@index([startDate])
}

model LeaveApproval {
  id            Int      @id @default(autoincrement())
  leaveRequestId Int
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approverId     Int
  approver       User     @relation(fields: [approverId], references: [id])
  status         String   // approved, rejected
  note           String?
  decidedAt      DateTime @default(now())

  @@index([leaveRequestId])
  @@index([approverId])
}

model Salary {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  baseSalary   Float
  allowances   Float    @default(0)
  deductions   Float    @default(0)
  gross        Float
  net          Float
  status       String   @default("generated") // generated, approved, paid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expenses     Expense[]

  @@unique([userId, month, year])
  @@index([month, year])
}

model ExpenseCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  deleted_at Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expenses  Expense[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  accountId   Int
  account     Accounts @relation(fields: [accountId], references: [id])
  amount      Float
  date        DateTime
  description String?
  createdById Int?
  createdBy   User?   @relation(fields: [createdById], references: [id])
  salaryId    Int?
  salary      Salary? @relation(fields: [salaryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([date])
}


model CashRegisterAssignment {
  id                Int            @id @default(autoincrement())
  entityType        String         // "store", "shop", "factory"
  entityId          Int            // ID of the entity (store, shop, or factory)
  cashRegisterId    Int
  cashRegister      CashRegister   @relation(fields: [cashRegisterId], references: [id])
  assignedAt        DateTime       @default(now())
  assignedById      Int?
  assignedBy        User?          @relation(fields: [assignedById], references: [id])
  isActive          Boolean        @default(true)
  notes             String?
  
  @@unique([entityType, entityId, cashRegisterId])
  @@index([entityType, entityId])
  @@index([cashRegisterId])
  @@index([assignedAt])
  @@index([isActive])
}

model CashRegister {
  id          Int       @id @default(autoincrement())
  name        String
  status      String
  deleted_at  Boolean              @default(false)
  cash_in_hand Float              @default(0)
  last_opened DateTime?
  last_closed DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  transactions  Transactions[]
  cashRegisterWithdraw CashRegisterWithdraw[]
  cashRegisterDeposit CashRegisterDeposit[]
  cashRegisterTransaction  CashRegisterRecord[]
  assignments       CashRegisterAssignment[]
  @@index([createdAt])
  @@index([status])
}

model CashRegisterRecord {
  id              Int       @id @default(autoincrement())

  cashRegisterId  Int
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id])

  opening_at      DateTime
  closing_at      DateTime?
  starting_cash   Float
  ending_cash     Float?

  shopId          Int?
  shop            Shop? @relation(fields: [shopId], references: [id])

  userId          Int
  user            User @relation("CashRegisterOpenedBy", fields: [userId], references: [id])
  closedById      Int?
  closedBy        User? @relation("CashRegisterClosedBy", fields: [closedById], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashRegisterId])
  @@index([shopId])
  @@index([userId])
  @@index([closedById])
}

model CashRegisterWithdraw {
  id              Int       @id @default(autoincrement())

  time            DateTime
  amount          Float

  cashRegisterId  Int?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  userId          Int?
  user            User? @relation(fields: [userId], references: [id])

  note            String?
  accountId       Int?
  account         Accounts? @relation(fields: [accountId], references: [id])
  bankAccountId   Int?
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashRegisterId])
  @@index([userId])
  @@index([time])
  @@index([accountId])
  @@index([bankAccountId])
}

model CashRegisterDeposit {
  id              Int       @id @default(autoincrement())

  time            DateTime
  amount          Float

  cashRegisterId  Int?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  userId          Int?
  user            User? @relation(fields: [userId], references: [id])

  note            String?
  accountId       Int?
  account         Accounts? @relation(fields: [accountId], references: [id])
  bankAccountId   Int?
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashRegisterId])
  @@index([userId])
  @@index([time])
  @@index([accountId])
  @@index([bankAccountId])
}


model Transactions {
  id                       Int       @id @default(autoincrement())
  reference                String    @unique

  createdById              Int
  createdBy                User      @relation(fields: [createdById], references: [id])

  cashRegisterId           Int?
  cashRegister             CashRegister? @relation(fields: [cashRegisterId], references: [id])

  bankAccountId           Int?
  bankAccount             BankAccount?   @relation(fields: [bankAccountId], references: [id])

  accountId                Int
  account                  Accounts  @relation(fields: [accountId], references: [id])

  saleId                   Int?
  sale                     Sale?     @relation(fields: [saleId], references: [id])

  purchaseId               Int?
  purchase                 Purchase? @relation(fields: [purchaseId], references: [id])

  purpose                  String?
  added_to_account         Boolean?
  amount                   Float?
  payment_method           String?
  current_account_balance  Float?
  note                     String?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([createdById])
  @@index([cashRegisterId])
  @@index([accountId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([createdAt])
}

model EntityAccount {
  id          Int       @id @default(autoincrement())
  entityType  String    // "store", "shop", "factory"
  entityId    Int       
  accountId   Int
  account     Accounts  @relation(fields: [accountId], references: [id])
  isPrimary   Boolean   @default(false)
  assignedAt  DateTime  @default(now())
  assignedById Int?
  assignedBy  User?     @relation(fields: [assignedById], references: [id])

  @@unique([entityType, entityId, accountId])
  @@index([entityType, entityId])
  @@index([accountId])
  @@index([assignedAt])
}

model Material {
  id                  Int                  @id @default(autoincrement())
  name                String
  description         String?
  category            String?
  brand               String?
  alternative_names   Json?
  barcode             String?              @unique
  image               String?
  unit                String
  alternative_units   Json?
  unit_cost           Float
  sale_price          Float?  
  current_stock       Float                @default(0)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  deleted_at          Boolean              @default(false)
  alert_quantity      Float                @default(0)
  ProductMaterial     ProductMaterial[]
  storeMaterials      StoreMaterial[]
  productionMaterials ProductionMaterial[]
  purchaseItems       PurchaseItem[]
  shopMaterial        ShopMaterial[]
  
  factoryMaterials    FactoryMaterial[]
  saleItem            SaleItem[]
  saleReturnItem      SaleReturnItem[]
  materialRepairItem  MaterialRepairItem[]
  ScrapMaterial       ScrapMaterial[]
  purchaseShipmentItems PurchaseShipmentItem[]
  purchaseReturnItems     PurchaseReturnItem[]
  purchaseReturnCompensationItems PurchaseReturnCompensationItem[]
  transferReceiptItems TransferReceiptItem[]
  transferItems      TransferItem[]
  warranties            UserWarranty[]
  requisitionItems      RequisitionItem[]
  requisitionSectionItems RequisitionSectionItem[]
  stockAdjustments      StockAdjustment[]
  repairOrderItems      RepairOrderItem[]
  damageRecordItems     DamageRecordItem[]
}

model Unit {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

model UnitRelation {
  id          Int      @id @default(autoincrement())
  primaryUnit String
  relatedUnit String
  multiplier  Float
  note        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([primaryUnit, relatedUnit])
  @@index([primaryUnit])
  @@index([relatedUnit])
  @@index([status])
  @@index([createdAt])
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@index([createdAt])
}

model Product {
  id                      Int                      @id @default(autoincrement())
  name                    String
  description             String?
  brand                   String?
  image                   String?
  unit                    String                   @default("unit")
  alternative_units       Json?
  alternative_names       Json?
  sale_price              Float
  wholesale_price         Float
  cost                    Float
  barcode                 String?                  @unique
  defaultWarrantyDays     Int?                     @default(0)
  category                String?
  stock                   Int                      @default(0)
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  deleted_at              Boolean                  @default(false)
  alert_quantity          Int                      @default(0) 
  materials               ProductMaterial[]
  productionProducts      ProductionProducts[]
  storeProducts           StoreProduct[]
  saleItem                SaleItem[]
  warranties              UserWarranty[]
  saleReturnItem           SaleReturnItem[]
  shopProduct             ShopProduct[]
  
  factoryProducts         FactoryProduct[]
  purchaseItem            PurchaseItem[]
  productRepairItem       ProductRepairItem[]
  scrapProduct            ScrapProduct[]
  purchaseShipmentItems   PurchaseShipmentItem[]
  purchaseReturnItems     PurchaseReturnItem[]
  purchaseReturnCompensationItems PurchaseReturnCompensationItem[]
  transferReceiptItems    TransferReceiptItem[]
  transferItems           TransferItem[]
  requisitionItems        RequisitionItem[]
  requisitionSectionItems RequisitionSectionItem[]
  stockAdjustments        StockAdjustment[]
  repairOrderItems        RepairOrderItem[]
  damageRecordItems       DamageRecordItem[]
  productCollection       ProductCollection[]
}

model ProductMaterial {
  product_id        Int
  material_id       Int
  material_quantity Float
  price             Float

  product  Product  @relation(fields: [product_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([product_id, material_id])
}

model Factory {
  id          Int          @id @default(autoincrement())
  name        String
  phone       String?
  manager     String?
  email       String?
  address     String?
  deleted_at  Boolean      @default(false)
  productions Production[] // Added for relation
  factoryProducts FactoryProduct[]
  factoryMaterials FactoryMaterial[]
  stockAdjustments StockAdjustment[]
  requisitionSections RequisitionSection[]
  damageRecords DamageRecord[]
  transfersFromFactory Transfer[] @relation("TransferFromFactory")
  transfersToFactory Transfer[] @relation("TransferToFactory")
}
model Production {
  id                      Int                      @id @default(autoincrement()) // Changed to Int
  reference               String                   @unique
  start_date              DateTime
  estimated_end_date      DateTime
  end_date                DateTime?
  factoryId               Int
  factory                 Factory                  @relation(fields: [factoryId], references: [id])
  status                  String                   @default("pending") // e.g., "pending", "running", "done"
  attachments             String? // Changed to String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  requisitionId           Int?
  requisitionSectionId    Int?
  requisition             Requisition?             @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  requisitionSection      RequisitionSection?      @relation(fields: [requisitionSectionId], references: [id], onDelete: SetNull)
  productionProducts      ProductionProducts[]
  productionMaterials     ProductionMaterial[]

  @@index([requisitionId])
  @@index([requisitionSectionId])
}

model Store {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  address                 String?
  store_keeper            String?
  mobile                  String?
  deleted_at              Boolean                  @default(false)
  storeMaterials          StoreMaterial[]
  storeProducts           StoreProduct[]
  stockAdjustments        StockAdjustment[]
  requisitionSections     RequisitionSection[]
  damageRecords           DamageRecord[]
  transfersFromStore      Transfer[] @relation("TransferFromStore")
  transfersToStore        Transfer[] @relation("TransferToStore")
  
  //sales                   Sale[]
  //saleReturns             SaleReturn[]
}

model StoreMaterial {
  store_id    Int
  material_id Int
  stock       Float @default(0)
  avg_cost   Float?
  sale_price Float?
  alert_quantity Float?
  scrap      Float? @default(0)
  deleted_at Boolean @default(false)
  batchDetails Json?
  store    Store    @relation(fields: [store_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([store_id, material_id])
}

model StoreProduct {
  store_id   Int
  product_id Int
  stock      Float @default(0)
  avg_cost  Float?
  sale_price Float?
  alert_quantity Float?
  scrap      Float? @default(0)
  deleted_at Boolean @default(false)
  batchDetails Json?
  store   Store   @relation(fields: [store_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([store_id, product_id])
}

model ProductionProducts {
  id             Int        @id @default(autoincrement()) // Changed to Int
  productionId   Int // Changed to Int
  production     Production @relation(fields: [productionId], references: [id])
  productId      Int
  product        Product    @relation(fields: [productId], references: [id])
  code           String
  batchNumber    String?
  expiryDate     DateTime?
  manufactureDate DateTime?
  batchNotes     String?
  quantity       Float
  unit_cost      Float
  received       Float      @default(0)
  scrap          Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ProductionMaterial {
  id           Int        @id @default(autoincrement())
  productionId Int
  production   Production @relation(fields: [productionId], references: [id])
  materialId   Int
  material     Material   @relation(fields: [materialId], references: [id])
  quantity     Float
  price        Float
  scrap        Float      @default(0)
  fineMaterial Float      @default(0)

  @@unique([productionId, materialId])
}



model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  mobile    String?
  address   String?
  deleted_at Boolean @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[] @relation("SupplierPurchases")
  purchaseReturns PurchaseReturn[]
}

model Purchase {
  id         Int      @id @default(autoincrement())
  reference   String?       @unique
  supplierId Int
  destinationType String? // New: "store", "shop", "factory"
  destinationId   Int?    // New: ID of store/shop/factory
  supplier   Supplier @relation(fields: [supplierId], references: [id], name: "SupplierPurchases")
  createdAt  DateTime @default(now())
  grandTotal   Float
  paidAmount   Float     @default(0)
  shippingStatus String   @default("pending")
  shippingCost Float?
  discount     Float?
  tax          Float?
  purchaseItems PurchaseItem[]
  purchaseShipments PurchaseShipment[]
  purchaseReturns PurchaseReturn[]
  transactions Transactions[]

  accountId       Int?          
  account         Accounts?     @relation(fields: [accountId], references: [id])

  @@index([destinationType])
  @@index([destinationId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  materialId Int?
  material   Material? @relation(fields: [materialId], references: [id])
  productId  Int?
  product    Product?  @relation(fields: [productId], references: [id])
  itemType   String   @default("material") // "material" or "product"
  selectedName String?
  selectedUnit String?
  selectedQuantity Float?
  batchNumber    String?
  expiryDate     DateTime?
  manufactureDate DateTime?
  batchNotes     String?
  quantity   Float
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  shipmentItems PurchaseShipmentItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@unique([purchaseId, productId, materialId])
  @@index([productId])
  @@index([materialId])
}

model PurchaseShipment {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  reference  String?  @unique
  status     String   @default("pending")
  note       String?
  receivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      PurchaseShipmentItem[]

  @@index([purchaseId])
}

model PurchaseShipmentItem {
  id              Int      @id @default(autoincrement())
  shipmentId      Int
  shipment        PurchaseShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  purchaseItemId  Int?
  purchaseItem    PurchaseItem? @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  itemType        String   @default("material")
  materialId      Int?
  material        Material? @relation(fields: [materialId], references: [id])
  productId       Int?
  product         Product?  @relation(fields: [productId], references: [id])
  quantity        Float
  received_quantity Float  @default(0)
  createdAt       DateTime @default(now())

  @@index([shipmentId])
  @@index([purchaseItemId])
  @@index([materialId])
