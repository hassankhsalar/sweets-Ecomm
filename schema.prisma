  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  items            RequisitionSectionItem[]
  transfers        Transfer[]
  productions      Production[]

  @@unique([requisitionId, sectionNo])
  @@index([requisitionId])
  @@index([status])
  @@index([destinationType, destinationId])
  @@index([storeId])
  @@index([shopId])
  @@index([factoryId])
}

model RequisitionSectionItem {
