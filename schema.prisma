model Sale {
  id          Int          @id @default(autoincrement())
  reference   String       @unique
  //storeId     Int?
  shopId      Int?
  //store       Store?        @relation(fields: [storeId], references: [id])
  shop        Shop?        @relation(fields: [shopId], references: [id])
  bankAccountId Int?
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  bankName    String?
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  totalAmount Float
  total_cost  Float?
  discount    Float        @default(0)
  grandTotal  Float
  paidAmount  Float        @default(0)
  paymentType String       @default("cash") // e.g. cash, card, mobile
  createdById Int?
  transactionStatus String @default("open") // open | closed
  transactionClosedById Int?
  transactionClosedAt DateTime?
  editStatus String @default("closed") // open | closed
  editGrantedToUserId Int?
  editGrantedByUserId Int?
  editOpenedAt DateTime?
  editClosedAt DateTime?
